# ── Server ───────────────────────────────────────────────
PORT=3000
BASE_URL=https://yourdomain.com

# ── Supabase (newsletter signup) ─────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ── Supabase Storage (paid PDF delivery) ─────────────────
# Secret/service_role key — bypasses RLS to read the private bucket. Server-side ONLY.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
SUPABASE_PDF_BUCKET=digital-products
SUPABASE_PDF_PATH=The_Nervous_System_Field_Manual.pdf

# ── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...            # Create in Stripe dashboard: $27 one-time

# ── Email (SMTP) ─────────────────────────────────────────
SMTP_HOST=smtp.brevo.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=Bobby Harris <support@battlefieldessentials.com>

# ── Klaviyo ──────────────────────────────────────────────
KLAVIYO_API_KEY=pk_...
KLAVIYO_LIST_ID=                     # "NSFM Buyers" list ID

# ── PDF ──────────────────────────────────────────────────
# Delivered from Supabase Storage (see above). PDF_DISPLAY_NAME sets the download filename.
PDF_DISPLAY_NAME=The Nervous System Field Manual

# ── Download limits ──────────────────────────────────────
DOWNLOAD_MAX_USES=3
DOWNLOAD_EXPIRY_HOURS=48

# ── Admin panel ──────────────────────────────────────────
ADMIN_SECRET=change_me_to_a_long_random_string
