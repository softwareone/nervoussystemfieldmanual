<!DOCTYPE html>
<html lang="en"><head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>
<meta name="description" content="<%= meta_description %>">
<meta name="facebook-domain-verification" content="8rbq4hnenoe60zotvh6b5wfp7c4r6k">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
<link href="https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400;1,500&family=Barlow+Semi+Condensed:wght@500;600;700&family=Oswald:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
  :root{
    --bg:#0c0b0a;
    --panel:#100d0b;
    --gold:#c8902c;
    --gold-bright:#dca63f;
    --ink:#f3efe8;
    --muted:#9d968b;
    --muted-2:#7e776c;
    --line:rgba(255,255,255,.10);
    --maxw:1180px;
    --textw:740px;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{background:var(--bg);color:var(--ink);font-family:"Barlow",system-ui,sans-serif;-webkit-font-smoothing:antialiased;overflow-x:hidden}

  .container{max-width:var(--maxw);margin:0 auto;padding:0 48px}
  section{position:relative}

  /* shared type */
  .eyebrow{display:inline-flex;flex-direction:column;align-items:flex-start}
  .eyebrow .k{font-family:"Oswald";font-weight:500;font-size:14px;letter-spacing:.24em;text-transform:uppercase;color:var(--gold)}
  .eyebrow .rule{width:60px;height:2px;background:var(--gold);margin-top:16px;opacity:.85}
  .h2{font-family:"Oswald";font-weight:700;text-transform:uppercase;font-size:clamp(32px,4vw,56px);line-height:1.0;letter-spacing:.005em;color:#f6f2ea;text-wrap:balance}
  .lead{font-size:clamp(16px,1.2vw,18.5px);line-height:1.68;color:#cfc8bc}
  .lead.muted{color:var(--muted)}
  .textcol{max-width:var(--textw)}
  strong{color:#f0e9dc;font-weight:600}
  .gold{color:var(--gold-bright)}

  .btn{font-family:"Oswald";font-weight:600;font-size:14px;letter-spacing:.1em;text-transform:uppercase;cursor:pointer;border:1px solid transparent;padding:17px 30px;transition:.18s;text-decoration:none;display:inline-flex;align-items:center;justify-content:center}
  .btn-primary{background:var(--gold);color:#1a140a}
  .btn-primary:hover{background:var(--gold-bright)}
  .btn-ghost{background:transparent;border-color:rgba(255,255,255,.22);color:var(--ink)}
  .btn-ghost:hover{border-color:var(--gold);color:var(--gold-bright)}

  /* ============ HERO ============ */
  .hero{display:flex;align-items:center;min-height:92vh;padding:96px 0 40px;
    background:
      radial-gradient(120% 90% at 78% 42%, rgba(200,144,44,.10), transparent 55%),
      radial-gradient(140% 120% at 50% 0%, #1a1611, var(--bg) 60%);
    overflow:hidden}
  .hero::after{content:"";position:absolute;inset:0;background:radial-gradient(120% 120% at 50% 130%, transparent 62%, rgba(0,0,0,.55));pointer-events:none}
  .hero .wrap{display:grid;grid-template-columns:1.05fr .82fr;gap:64px;align-items:center;position:relative;z-index:2;width:100%}
  .hero h1{font-family:"Oswald";font-weight:700;text-transform:uppercase;font-size:clamp(34px,4.2vw,58px);line-height:1.0;letter-spacing:.005em;margin:30px 0 22px;color:#f6f2ea;text-wrap:balance}
  .hero .sub{font-family:"Oswald";font-weight:500;color:var(--gold-bright);font-size:clamp(17px,1.55vw,22px);line-height:1.42;max-width:30ch;margin-bottom:20px}
  .hero .body{font-size:clamp(15px,1.15vw,17px);line-height:1.6;color:var(--muted);max-width:44ch;margin-bottom:36px}
  .hero .body b{color:#e7decf;font-weight:600}
  .cta-row{display:flex;gap:16px;flex-wrap:wrap}
  .book{justify-self:center;position:relative}
  .book img{display:block;width:min(360px,36vw);height:auto;border-radius:3px;box-shadow:0 40px 80px -20px rgba(0,0,0,.8),0 0 0 1px rgba(255,255,255,.04)}
  .book::before{content:"";position:absolute;inset:-8% -6% -10% -6%;z-index:-1;background:radial-gradient(closest-side, rgba(200,144,44,.18), transparent 70%);filter:blur(10px)}

  /* trust bar */
  .trust{border-top:1px solid var(--line);border-bottom:1px solid var(--line);background:rgba(0,0,0,.28)}
  .trust .row{display:flex;justify-content:center;flex-wrap:wrap;padding:18px 0}
  .trust .item{font-family:"Oswald";font-weight:500;font-size:13px;letter-spacing:.1em;text-transform:uppercase;color:#b8b0a3;padding:4px 28px;position:relative}
  .trust .item:not(:last-child)::after{content:"";position:absolute;right:0;top:50%;transform:translateY(-50%);height:14px;width:1px;background:var(--line)}
  .trust .item b{color:var(--gold);font-weight:600;margin-right:9px}

  /* ============ generic section ============ */
  .sec{padding:104px 0}
  .sec.panel{background:var(--panel);border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
  .sec-head{margin-bottom:46px}
  .sec-head .h2{margin-top:26px}

  /* mirror */
  .mirror .lead + .lead{margin-top:22px}
  .callout{border-left:3px solid var(--gold);background:linear-gradient(90deg,rgba(200,144,44,.06),transparent);padding:26px 30px;margin:44px 0}
  .callout .tag{font-family:"Oswald";font-weight:600;font-size:12px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);display:block;margin-bottom:14px}
  .callout p{font-family:"Barlow";font-style:italic;font-size:clamp(18px,1.55vw,23px);line-height:1.5;color:#ece5d8}
  .emph{background:rgba(255,255,255,.025);border:1px solid var(--line);padding:30px 32px;margin:40px 0 48px}
  .emph p{font-size:clamp(15.5px,1.18vw,18px);line-height:1.66;color:#cfc8bc}
  .emph .hl{font-family:"Oswald";font-weight:600;color:#f6f2ea;text-transform:none;font-size:1.06em}
  .feel-label{font-family:"Oswald";font-weight:500;font-size:13px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted-2);margin:0 0 22px}
  .feel-list{list-style:none;display:flex;flex-direction:column;gap:18px;max-width:860px}
  .feel-list li{display:flex;gap:18px;align-items:flex-start;font-size:clamp(15.5px,1.15vw,17.5px);line-height:1.5;color:#d8d1c5}
  .feel-list .mk{flex:none;color:var(--gold);font-family:"Oswald";font-weight:700;margin-top:1px}

  /* mechanism phases */
  .mech .lead + .lead{margin-top:22px}
  .phases-label{font-family:"Oswald";font-weight:500;font-size:13px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted-2);margin:54px 0 22px}
  .phases{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
  .phase{border:1px solid var(--line);border-top:2px solid var(--gold);background:rgba(255,255,255,.018);padding:30px 28px 34px;position:relative}
  .phase .no{font-family:"Oswald";font-weight:700;font-size:46px;line-height:1;color:rgba(200,144,44,.45);letter-spacing:.02em}
  .phase h3{font-family:"Oswald";font-weight:600;text-transform:uppercase;letter-spacing:.04em;font-size:22px;color:#f3ecdf;margin:14px 0 8px}
  .phase .ph-tag{font-family:"Oswald";font-weight:500;font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--gold);margin-bottom:14px}
  .phase p{font-size:15px;line-height:1.62;color:var(--muted)}
  .phase p b{color:#ddd4c6;font-weight:600}

  /* proof */
  .vbox{border:1px solid var(--line);border-left:3px solid var(--gold);background:rgba(255,255,255,.022);padding:30px 34px;margin-bottom:54px;max-width:920px}
  .vbox p{font-size:clamp(15.5px,1.15vw,17.5px);line-height:1.66;color:#cfc8bc}
  .cols{display:grid;grid-template-columns:1fr 1fr;gap:24px}
  .col{border:1px solid var(--line);background:rgba(255,255,255,.015);padding:30px 30px 34px}
  .col.no{opacity:.92}
  .col h4{font-family:"Oswald";font-weight:600;font-size:14px;letter-spacing:.14em;text-transform:uppercase;display:flex;align-items:center;gap:11px;margin-bottom:22px}
  .col.yes h4{color:var(--gold)}
  .col.no h4{color:var(--muted-2)}
  .col h4 .ic{width:22px;height:22px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:12px;flex:none}
  .col.yes h4 .ic{background:rgba(200,144,44,.16);color:var(--gold)}
  .col.no h4 .ic{background:rgba(255,255,255,.05);color:var(--muted-2)}
  .col ul{list-style:none;display:flex;flex-direction:column;gap:17px}
  .col li{display:flex;gap:13px;align-items:flex-start;font-size:15.5px;line-height:1.5}
  .col.yes li{color:#d6cfc3}
  .col.no li{color:var(--muted)}
  .col li .m{flex:none;margin-top:2px;font-family:"Oswald";font-weight:700;font-size:13px}
  .col.yes li .m{color:var(--gold)}
  .col.no li .m{color:var(--muted-2)}
  .founder{margin-top:54px;border:1px solid var(--line);background:rgba(255,255,255,.02);padding:34px 36px;max-width:920px;position:relative}
  .founder::before{content:"";position:absolute;left:0;top:0;bottom:0;width:3px;background:linear-gradient(var(--gold),transparent)}
  .founder p{font-family:"Barlow";font-style:italic;font-size:clamp(16px,1.25vw,19px);line-height:1.6;color:#d8d1c5}
  .founder .sig{font-family:"Oswald";font-style:normal;font-weight:600;letter-spacing:.04em;text-transform:uppercase;color:var(--gold);font-size:14px;margin-top:20px;display:block}

  /* close */
  .close{background:
      radial-gradient(120% 80% at 50% 0%, #1a1611, var(--panel) 65%);
    border-top:1px solid var(--line)}
  .bignum{font-family:"Oswald";font-weight:700;line-height:.86;color:#f6f2ea;font-size:clamp(64px,11vw,150px);letter-spacing:-.01em;margin:30px 0 6px}
  .bignum span{color:var(--gold)}
  .close .math{font-size:clamp(16px,1.2vw,18.5px);line-height:1.68;color:#cfc8bc;max-width:var(--textw);margin-top:18px}
  .close .math + .math{margin-top:18px}
  .guarantee{border:1px solid rgba(200,144,44,.4);background:rgba(200,144,44,.05);padding:30px 34px;margin:50px 0;max-width:920px}
  .guarantee .tag{font-family:"Oswald";font-weight:600;font-size:13px;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);display:flex;align-items:center;gap:11px;margin-bottom:16px}
  .guarantee p{font-size:clamp(15.5px,1.15vw,17.5px);line-height:1.64;color:#d8d1c5}
  .urgency{display:flex;gap:16px;align-items:flex-start;max-width:920px;color:var(--muted);font-size:15.5px;line-height:1.6;border-top:1px solid var(--line);padding-top:30px}
  .urgency .dot{flex:none;width:8px;height:8px;border-radius:50%;background:var(--gold);margin-top:7px;box-shadow:0 0 0 4px rgba(200,144,44,.15)}
  .urgency b{color:#e2d9ca;font-weight:600}

  /* final cta band */
  .finalcta{text-align:center;padding:96px 0 104px;background:
      radial-gradient(100% 120% at 50% 0%, rgba(200,144,44,.10), transparent 60%), var(--bg);
    border-top:1px solid var(--line)}
  .finalcta .h2{margin:0 auto 14px;max-width:18ch}
  .finalcta p{color:var(--muted);font-size:17px;max-width:42ch;margin:0 auto 36px;line-height:1.55}
  .finalcta .btn-primary{font-size:16px;padding:21px 44px}
  .finalcta .micro{margin-top:22px;font-family:"Oswald";font-weight:500;font-size:12.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted-2)}

  footer{border-top:1px solid var(--line);padding:34px 0;background:var(--panel)}
  footer .row{display:flex;justify-content:space-between;align-items:center;gap:20px;flex-wrap:wrap}
  footer .brand{font-family:"Oswald";font-weight:600;letter-spacing:.16em;text-transform:uppercase;font-size:14px;color:#cabfa9}
  footer .brand small{display:block;font-weight:400;font-size:11px;letter-spacing:.2em;color:var(--muted-2);margin-top:5px}
  footer .disc{font-size:12.5px;color:var(--muted-2);max-width:520px;line-height:1.5}

  @media(max-width:900px){
    .container{padding:0 24px}
    .hero{min-height:auto;padding:90px 0 40px}
    .hero .wrap{grid-template-columns:1fr;gap:38px}
    .book{order:-1}
    .book img{width:min(230px,52vw)}
    .hero .sub,.hero .body{max-width:none}
    .phases{grid-template-columns:1fr}
    .cols{grid-template-columns:1fr}
    .sec{padding:74px 0}
    .trust .item{padding:4px 14px;font-size:11px}
    .trust .item:not(:last-child)::after{display:none}
    .urgency,.finalcta .h2,.finalcta p{padding-left:0}
  }
</style>
